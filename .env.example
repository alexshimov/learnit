# Local development needs NO env vars — the app falls back to a SQLite
# file at ./local.db automatically.
#
# For production (Vercel), create a free Turso database and set these:
#   1. Install: brew install tursodatabase/tap/turso  (or see turso.tech)
#   2. turso db create learnit
#   3. turso db show learnit --url            -> DATABASE_URL
#   4. turso db tokens create learnit         -> DATABASE_AUTH_TOKEN
# Then add both as Environment Variables in your Vercel project settings.

DATABASE_URL=
DATABASE_AUTH_TOKEN=
